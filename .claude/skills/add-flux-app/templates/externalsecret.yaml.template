---
# yaml-language-server: $schema=https://kubernetes-schemas.pages.dev/external-secrets.io/externalsecret_v1.json
apiVersion: external-secrets.io/v1
kind: ExternalSecret
metadata:
  name: {{SECRET_NAME}}
  namespace: {{NAMESPACE}}
spec:
  refreshInterval: 1h
  secretStoreRef:
    kind: ClusterSecretStore
    name: onepassword-connect
  target:
    name: {{SECRET_NAME}}
    creationPolicy: Owner
  data:
    # SDK provider combined-key syntax: "<1Password item>/<field>"
    - secretKey: {{K8S_SECRET_KEY}}
      remoteRef:
        key: "{{ONEPASSWORD_ITEM}}/{{ONEPASSWORD_FIELD}}"
  # Alternative: pull every field from a 1Password item as one Secret
  # dataFrom:
  #   - extract:
  #       key: "{{ONEPASSWORD_ITEM}}"
